{
  "name": "@skipbo/game-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests --ext ts --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage --coverage.reporter=lcovonly --coverage.reporter=text-summary",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "immer": "^11.1.11"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
