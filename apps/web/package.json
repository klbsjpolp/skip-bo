{
  "name": "@skipbo/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "mock:relay": "node --experimental-strip-types tests/mock-relay/serve.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcovonly --coverage.reporter=text-summary",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "vitest --ui",
    "test:visual": "playwright test --project=chromium-desktop --project=chromium-mobile",
    "test:visual:update": "playwright test --project=chromium-desktop --project=chromium-mobile --update-snapshots=all",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@klbsjpolp/realtime-core": "^0.1.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/react": "^10.64.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@skipbo/game-core": "workspace:*",
    "@skipbo/skipbo-runtime": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "immer": "^11.1.11",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "workbox-window": "^7.4.1",
    "xstate": "^5.32.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "4.1.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-build": "^7.4.1",
    "ws": "^8.21.0"
  }
}
