{
  "name": "skip-bo-workspace",
  "private": true,
  "version": "1.43.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm --filter @skipbo/game-core build && pnpm --filter @skipbo/multiplayer-protocol build && pnpm --filter @skipbo/realtime-api build && pnpm --filter @skipbo/web build",
    "commit": "cz",
    "dev": "pnpm dev:web --host",
    "dev:api": "pnpm --filter @skipbo/realtime-api dev",
    "dev:web": "pnpm --filter @skipbo/web dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,yml,yaml}\"",
    "lint": "pnpm format:check && pnpm --filter @skipbo/game-core lint && pnpm --filter @skipbo/multiplayer-protocol lint && pnpm --filter @skipbo/realtime-api lint && pnpm --filter @skipbo/web lint",
    "prepare": "husky",
    "preview": "pnpm --filter @skipbo/web preview",
    "release": "commit-and-tag-version",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "release:first": "commit-and-tag-version --first-release",
    "tofu:apply": "pnpm --dir infra/terraform apply:prod",
    "tofu:init": "pnpm --dir infra/terraform init:prod",
    "tofu:fmt": "pnpm --dir infra/terraform fmt",
    "tofu:plan": "pnpm --dir infra/terraform plan:prod",
    "tofu:validate": "pnpm --dir infra/terraform validate:prod",
    "test": "pnpm --filter @skipbo/game-core test && pnpm --filter @skipbo/multiplayer-protocol test && pnpm --filter @skipbo/realtime-api test && pnpm --filter @skipbo/web test",
    "test:e2e": "pnpm --filter @skipbo/web test:e2e",
    "test:e2e:ui": "pnpm --filter @skipbo/web test:e2e:ui",
    "test:ui": "pnpm --filter @skipbo/web test:ui",
    "test:visual": "pnpm --filter @skipbo/web test:visual",
    "test:visual:update": "pnpm --filter @skipbo/web test:visual:update",
    "test:watch": "pnpm --filter @skipbo/web test:watch",
    "typecheck": "pnpm --filter @skipbo/game-core typecheck && pnpm --filter @skipbo/multiplayer-protocol typecheck && pnpm --filter @skipbo/realtime-api typecheck && pnpm --filter @skipbo/web typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "commit-and-tag-version": "^12.7.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
