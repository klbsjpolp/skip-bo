{
  "name": "skip-bo-workspace",
  "private": true,
  "version": "2.12.4",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm --filter @skipbo/game-core build && pnpm --filter @skipbo/skipbo-runtime build && pnpm --filter @skipbo/web build",
    "commit": "cz",
    "dev": "pnpm dev:web --host",
    "dev:web": "pnpm --filter @skipbo/web dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,yml,yaml}\"",
    "lint": "pnpm format:check && pnpm --filter @skipbo/game-core lint && pnpm --filter @skipbo/skipbo-runtime lint && pnpm --filter @skipbo/web lint",
    "prepare": "husky",
    "preview": "pnpm --filter @skipbo/web preview",
    "release": "commit-and-tag-version",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "release:first": "commit-and-tag-version --first-release",
    "test": "pnpm --filter @skipbo/game-core test && pnpm --filter @skipbo/skipbo-runtime test && pnpm --filter @skipbo/web test",
    "test:coverage": "pnpm --filter @skipbo/game-core test:coverage && pnpm --filter @skipbo/skipbo-runtime test:coverage && pnpm --filter @skipbo/web test:coverage",
    "test:e2e": "pnpm --filter @skipbo/web test:e2e",
    "test:e2e:ui": "pnpm --filter @skipbo/web test:e2e:ui",
    "test:ui": "pnpm --filter @skipbo/web test:ui",
    "test:visual": "pnpm --filter @skipbo/web test:visual",
    "test:visual:update": "pnpm --filter @skipbo/web test:visual:update",
    "test:watch": "pnpm --filter @skipbo/web test:watch",
    "typecheck": "pnpm --filter @skipbo/game-core typecheck && pnpm --filter @skipbo/skipbo-runtime typecheck && pnpm --filter @skipbo/web typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "commit-and-tag-version": "^12.7.3",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
